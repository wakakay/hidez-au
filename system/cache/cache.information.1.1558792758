";}i:22;a:7:{s:14:"information_id";s:2:"30";s:6:"bottom";s:1:"0";s:10:"sort_order";s:1:"6";s:6:"status";s:1:"1";s:11:"language_id";s:1:"1";s:5:"title";s:30:"Hidez  Sponsorship Application";s:11:"description";s:9534:"&lt;div class=&quot;forms&quot;&gt;
	&lt;div class=&quot;p&quot;&gt;
		&lt;p&gt;
			&amp;nbsp;If you&amp;#39;re a successful Equestrian sportsman or woman or successful Greyhound Trainer and would like to be a Hidez ambassador, please complete the form below to apply for a Hidez sponsorship.&lt;/p&gt;
	&lt;/div&gt;
	&lt;form action=&quot;sendmail.php&quot; enctype=&quot;multipart/form-data&quot; method=&quot;post&quot;&gt;
		&lt;input id=&quot;mod&quot; name=&quot;mod&quot; type=&quot;hidden&quot; value=&quot;1&quot; /&gt;
		&lt;ul&gt;
			&lt;li&gt;
				&lt;label&gt;&lt;span&gt;*&lt;/span&gt; First name&lt;/label&gt; &lt;input autocomplete=&quot;OFF&quot; maxlength=&quot;255&quot; name=&quot;FirstName&quot; required=&quot;&quot; tabindex=&quot;1&quot; /&gt;&lt;/li&gt;
			&lt;li&gt;
				&lt;label&gt;&lt;span&gt;*&lt;/span&gt; Last name&lt;/label&gt; &lt;input autocomplete=&quot;OFF&quot; maxlength=&quot;255&quot; name=&quot;LastName&quot; required=&quot;&quot; tabindex=&quot;1&quot; /&gt;&lt;/li&gt;
			&lt;li&gt;
				&lt;label&gt;&lt;span&gt;*&lt;/span&gt; Gender&lt;/label&gt; &lt;input name=&quot;Gender&quot; tabindex=&quot;3&quot; type=&quot;radio&quot; value=&quot;Male&quot; /&gt;&lt;label class=&quot;rad&quot; for=&quot;Male&quot;&gt;Male&lt;/label&gt; &lt;input name=&quot;Gender&quot; tabindex=&quot;3&quot; type=&quot;radio&quot; value=&quot;Female&quot; /&gt;&lt;label class=&quot;rad&quot; for=&quot;Female&quot;&gt;Female&lt;/label&gt;&lt;/li&gt;
			&lt;li&gt;
				&lt;label&gt;Age&lt;/label&gt; &lt;input maxlength=&quot;15&quot; name=&quot;Age&quot; required=&quot;&quot; tabindex=&quot;4&quot; /&gt;&lt;/li&gt;
			&lt;li&gt;
				&lt;label&gt;Street Address&lt;/label&gt; &lt;input autocomplete=&quot;OFF&quot; maxlength=&quot;255&quot; name=&quot;StreetAddress&quot; required=&quot;&quot; tabindex=&quot;5&quot; /&gt;&lt;/li&gt;
			&lt;li&gt;
				&lt;label&gt;Address Line 2&lt;/label&gt; &lt;input autocomplete=&quot;OFF&quot; maxlength=&quot;255&quot; name=&quot;AddressLine&quot; required=&quot;&quot; tabindex=&quot;5&quot; /&gt;&lt;/li&gt;
			&lt;li&gt;
				&lt;label&gt;City&lt;/label&gt; &lt;input autocomplete=&quot;OFF&quot; maxlength=&quot;255&quot; name=&quot;City&quot; required=&quot;&quot; tabindex=&quot;6&quot; /&gt;&lt;/li&gt;
			&lt;li&gt;
				&lt;label&gt;State/Province/Region&lt;/label&gt; &lt;input autocomplete=&quot;OFF&quot; maxlength=&quot;255&quot; name=&quot;State&quot; required=&quot;&quot; tabindex=&quot;7&quot; /&gt;&lt;/li&gt;
			&lt;li&gt;
				&lt;label&gt;Postal/Zip Code&lt;/label&gt; &lt;input autocomplete=&quot;OFF&quot; name=&quot;Postal&quot; required=&quot;&quot; tabindex=&quot;8&quot; /&gt;&lt;/li&gt;
			&lt;li&gt;
				&lt;label&gt;Country &lt;/label&gt;&lt;input autocomplete=&quot;OFF&quot; name=&quot;Country&quot; required=&quot;&quot; tabindex=&quot;9&quot; /&gt;&lt;/li&gt;
			&lt;li&gt;
				&lt;label class=&quot;nopad&quot;&gt;&lt;span&gt;*&lt;/span&gt; Nationality/Country that you represent&lt;/label&gt; &lt;input autocomplete=&quot;OFF&quot; name=&quot;Nat&quot; required=&quot;&quot; tabindex=&quot;10&quot; /&gt;&lt;/li&gt;
			&lt;li&gt;
				&lt;label&gt;&lt;span&gt;*&lt;/span&gt; Email&lt;/label&gt; &lt;input autocomplete=&quot;OFF&quot; name=&quot;Email&quot; required=&quot;&quot; tabindex=&quot;11&quot; /&gt;&lt;/li&gt;
			&lt;li&gt;
				&lt;label&gt;Phone&lt;/label&gt; &lt;input autocomplete=&quot;OFF&quot; name=&quot;Phone&quot; required=&quot;&quot; tabindex=&quot;12&quot; /&gt;&lt;/li&gt;
		&lt;/ul&gt;
