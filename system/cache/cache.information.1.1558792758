&lt;tr&gt;	&lt;td&gt;6.2&lt;/td&gt;	&lt;td&gt;26-28&lt;/td&gt;	&lt;td&gt;66-70&lt;/td&gt;	&lt;td&gt;6H-7H&lt;/td&gt;	&lt;td&gt;MINIATURE-SMALL&lt;/td&gt;	&lt;/tr&gt;
